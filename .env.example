# API key for text/image embedding requests.
GEMINI_API_KEY="YOUR_API_KEY"

# Embedding model.
VIDEOSENSE_EMBEDDING_MODEL="gemini-embedding-2-preview"

# Frame extraction cadence in seconds.
VIDEOSENSE_FRAME_INTERVAL_SEC="2.0"

# Number of results to show.
VIDEOSENSE_TOP_K="3"

# Async indexing controls.
VIDEOSENSE_EMBED_CONCURRENCY="4"
VIDEOSENSE_EMBED_MAX_RETRIES="2"
VIDEOSENSE_EMBED_BACKOFF_SEC="1.0"

# Persistent index toggle.
VIDEOSENSE_ENABLE_PERSISTENCE="false"
VIDEOSENSE_PERSISTENCE_DIR=".videosense/chroma"
VIDEOSENSE_MIN_SIMILARITY="0.3"
VIDEOSENSE_FRAME_STRATEGY="scene"
VIDEOSENSE_SCENE_THRESHOLD="27.0"
VIDEOSENSE_MAX_VISUAL_FRAMES="300"
VIDEOSENSE_ENABLE_QUERY_EXPANSION="true"
VIDEOSENSE_RRF_K="60"
VIDEOSENSE_TRANSCRIPT_WEIGHT="1.15"
VIDEOSENSE_VISUAL_WEIGHT="1.0"
