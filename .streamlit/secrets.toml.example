# Streamlit Community Cloud secrets template.
#
# On Streamlit Cloud: paste these into the app's Settings -> Secrets editor.
# Locally: copy this file to `.streamlit/secrets.toml` (gitignored) and fill in
# real values. Keys here map 1:1 onto the environment variables read by
# AppConfig.from_env() — see src/runtime_env.py for the bridge.

# Required: Gemini API key for embeddings + LLM.
GEMINI_API_KEY = "your-gemini-api-key"

# Vector backend: auto | qdrant | chroma | memory.
# "auto" uses Qdrant when a URL is set and reachable, else falls back.
VIDEOSENSE_VECTOR_BACKEND = "auto"

# Qdrant Cloud (optional — omit to run on Chroma/in-memory only).
VIDEOSENSE_QDRANT_URL = "https://your-cluster.qdrant.io:6333"
VIDEOSENSE_QDRANT_API_KEY = "your-qdrant-api-key"
